# pdash — production / homelab environment file.
#
# Copy to `.env` (gitignored) and fill in the secrets. Most values are fine at
# the defaults; the variables you MUST set are at the top.
#
# For local development, use `.env.development.example` instead.

# ---------------------------------------------------------------------------
# Required on first launch
# ---------------------------------------------------------------------------

# Used by the backend container's entrypoint to bootstrap the admin password
# on first run. Once the DB exists, remove this from `.env` — leaving it in
# is harmless (the entrypoint short-circuits when the DB is present) but it
# discourages secret hygiene.
# PDASH_BOOTSTRAP_ADMIN_PASSWORD=changeme

# The MCP server authenticates to the backend with this secret. It is printed
# to the backend's stdout the first time the backend bootstraps itself
# (`python -m app.cli init ...` or first compose run with
# PDASH_BOOTSTRAP_ADMIN_PASSWORD set). Paste the value here. It never leaves
# this host — every service that reads it runs on the same compose network.
PDASH_SERVICE_SECRET=

# ---------------------------------------------------------------------------
# Backend (FastAPI) — env_prefix PDASH_
# ---------------------------------------------------------------------------

# SQLite file path inside the backend container. The compose file mounts
# ./data here; you usually don't need to change this.
PDASH_DATABASE_PATH=/data/pdash.db

# Cookie security. Must be `true` in production (Caddy terminates HTTPS).
PDASH_COOKIE_SECURE=true

# Session lifetime (seconds). Default 30 days.
PDASH_SESSION_LIFETIME_SECONDS=2592000

# Audit-blob spill threshold in bytes (32 KB by default).
PDASH_AUDIT_BLOB_THRESHOLD_BYTES=32768

# Pending approval TTL (default 7 days).
PDASH_PENDING_TTL_SECONDS=604800

# Agent file-drop dirs. Agents drop files into the inbox (must be on a mount the
# agent and the backend container share); registered files move into the store
# and are served to the dashboard. Default to siblings of pdash.db under /data.
PDASH_FILES_INBOX_PATH=/data/inbox
PDASH_FILES_STORE_PATH=/data/files
# Max registerable file size in bytes (25 MiB default).
PDASH_FILE_MAX_BYTES=26214400
# Comma-separated MIME allowlist; blank = accept any (risky types force-download).
PDASH_FILE_MIME_ALLOWLIST=

# Disable the /api/v1/docs Swagger UI in prod by setting to `false`.
PDASH_DOCS_ENABLED=true

# Logging.
PDASH_LOG_LEVEL=INFO
PDASH_LOG_JSON=true

# CORS — leave empty unless the frontend is on a separate origin.
# Provide as JSON list: ["https://other-app.example.com"]
# PDASH_CORS_ORIGINS=[]

# ---------------------------------------------------------------------------
# MCP server — env_prefix PDASH_
# ---------------------------------------------------------------------------

# Backend URL the MCP server hits internally. Inside docker-compose this is
# the service hostname. The MCP server is designed to run on the same
# host/compose network as the backend — pointing this at a remote backend is
# unsupported (remote *agents* connect to /mcp instead; see docs/deploy.md).
PDASH_BACKEND_URL=http://backend:8080

# MCP bind. Default 0.0.0.0:8090 inside the container.
PDASH_MCP_HOST=0.0.0.0
PDASH_MCP_PORT=8090

# Resolution cache TTL for (api_key -> agent) lookups; revocation takes
# effect within this window (≤30s).
PDASH_AUTH_CACHE_TTL_S=30

# Idempotency dedupe TTL.
PDASH_IDEM_DEDUPE_TTL_S=60

# httpx timeout (seconds) for backend calls from the MCP server.
PDASH_BACKEND_TIMEOUT_S=15

# ---------------------------------------------------------------------------
# Frontend (Next.js)
# ---------------------------------------------------------------------------

# Backend URL the Next.js server rewrites /api/* to. Inside compose this is
# the docker service name; on bare metal use http://localhost:8080.
# This variable is read at build time AND at server runtime; rebuild the
# image if you change it.
# PDASH_BACKEND_URL=http://backend:8080
