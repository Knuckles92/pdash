# pdash — local development environment.
#
# Copy to `.env` (gitignored) before `make setup`:
#   cp .env.development.example .env
#
# For production / homelab deploy use `.env.example` instead.

# ---------------------------------------------------------------------------
# Dev-only (used by scripts/setup-dev.sh; not read by the apps directly)
# ---------------------------------------------------------------------------

# Admin password for first-time `make setup` bootstrap. Insecure — local only.
PDASH_DEV_ADMIN_PASSWORD=dev

# ---------------------------------------------------------------------------
# Required after first setup (filled automatically by `make setup`)
# ---------------------------------------------------------------------------

PDASH_SERVICE_SECRET=

# ---------------------------------------------------------------------------
# Backend (FastAPI) — env_prefix PDASH_
# ---------------------------------------------------------------------------

# Overridden to an absolute path by scripts/dev.sh and setup-dev.sh.
# PDASH_DATABASE_PATH is set at runtime; default target is ./data/pdash.db
PDASH_DATABASE_PATH=

PDASH_COOKIE_SECURE=false
PDASH_SESSION_LIFETIME_SECONDS=2592000
PDASH_AUDIT_BLOB_THRESHOLD_BYTES=32768
PDASH_PENDING_TTL_SECONDS=604800
PDASH_DOCS_ENABLED=true
PDASH_LOG_LEVEL=INFO
PDASH_LOG_JSON=false

# Agent file-drop. Agents write files into the inbox dir; registered files are
# moved into the store dir and served to the dashboard. Defaults sit beside
# pdash.db inside the data dir, so leaving these blank is fine for local dev.
PDASH_FILES_INBOX_PATH=
PDASH_FILES_STORE_PATH=
PDASH_FILE_MAX_BYTES=26214400
# Comma-separated MIME allowlist; blank = accept any (risky types force-download).
PDASH_FILE_MIME_ALLOWLIST=

# Dashboard screenshots (optional, OFF by default in dev). The screenshot_page
# MCP tool renders the live frontend in headless Chromium via a separate sidecar
# (see screenshot/). `make dev` does NOT start it, so the tool reports
# "service unavailable" until you run the sidecar and point these at it.
# PDASH_FRONTEND_URL=http://127.0.0.1:3000
# PDASH_SCREENSHOT_SERVICE_URL=http://127.0.0.1:9000

# ---------------------------------------------------------------------------
# MCP + Frontend (shared backend URL)
# ---------------------------------------------------------------------------

PDASH_BACKEND_URL=http://127.0.0.1:8080
PDASH_MCP_HOST=127.0.0.1
PDASH_MCP_PORT=8090
# URL the backend probes to power the admin "MCP control center" (Settings → MCP).
PDASH_MCP_URL=http://127.0.0.1:8090
PDASH_AUTH_CACHE_TTL_S=30
PDASH_IDEM_DEDUPE_TTL_S=60
PDASH_BACKEND_TIMEOUT_S=15
